# 前端Dockerfile
# 直接使用预构建的前端文件,避免 Docker 中的构建权限问题
FROM nginx:alpine

# 复制本地已构建的 dist 文件夹
COPY dist /usr/share/nginx/html

# 注意: nginx.conf 由 docker-compose.yml 的 volumes 挂载,不需要在这里复制

# 暴露端口
EXPOSE 80

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD curl -f http://localhost:80/ || exit 1

# 启动Nginx
CMD ["nginx", "-g", "daemon off;"]
