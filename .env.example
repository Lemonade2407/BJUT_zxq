# ===========================================
# BJUT-ZXQ 项目环境配置文件
# ===========================================
# 使用说明:
# 1. 复制此文件为 .env (cp .env.example .env)
# 2. 修改下面的配置项为实际值
# 3. 不要将 .env 文件提交到 Git

# ===========================================
# MySQL 数据库配置
# ===========================================
# MySQL root 用户密码(必须设置强密码,至少8位,包含大小写字母、数字和特殊字符)
MYSQL_ROOT_PASSWORD=YourStrongPassword123!

# ===========================================
# 阿里云 OSS 配置
# ===========================================
# AccessKey ID (从阿里云控制台获取)
OSS_ACCESS_KEY_ID=LTAI你的AccessKeyID

# AccessKey Secret (从阿里云控制台获取)
OSS_ACCESS_KEY_SECRET=你的AccessKeySecret

# ===========================================
# 前端 API 地址配置
# ===========================================
# 生产环境的后端 API 地址
# 使用服务器公网 IP 或域名
VITE_API_BASE_URL=http://60.205.210.11/api

# ===========================================
# 其他可选配置
# ===========================================
# 服务器 IP 地址(用于显示访问地址)
SERVER_IP=60.205.210.11

# JVM 参数(可选,默认已配置在 docker-compose.yml 中)
# JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC
