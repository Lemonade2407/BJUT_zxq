<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//myBatis//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bjutzxq.server.mapper.WatchMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.bjutzxq.pojo.Watch">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="project_id" property="projectId"/>
        <result column="notification_type" property="notificationType"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, user_id, project_id, notification_type, created_at
    </sql>

    <!-- 新增关注 -->
    <insert id="insert" parameterType="com.bjutzxq.pojo.Watch" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO watch (
            user_id,
            project_id,
            notification_type,
            created_at
        ) VALUES (
            #{userId},
            #{projectId},
            #{notificationType},
            NOW()
        )
    </insert>
    
    <!-- 根据用户 ID 和项目 ID 查询关注记录 -->
    <select id="selectByUserIdAndProjectId" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM watch
        WHERE user_id = #{userId} AND project_id = #{projectId}
        LIMIT 1
    </select>
    
    <!-- 删除关注记录 -->
    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM watch WHERE id = #{id}
    </delete>
    
    <!-- 统计项目关注数 -->
    <select id="countByProjectId" resultType="int">
        SELECT COUNT(*) 
        FROM watch
        WHERE project_id = #{projectId}
    </select>
    
</mapper>
