<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bjutzxq.server.mapper.CategoryMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.bjutzxq.pojo.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="parent_id" property="parentId"/>
        <result column="sort_order" property="sortOrder"/>
    </resultMap>
    
    <!-- 插入分类 -->
    <insert id="insert" parameterType="com.bjutzxq.pojo.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, parent_id, sort_order)
        VALUES (#{name}, #{parentId}, #{sortOrder})
    </insert>
    
    <!-- 删除分类 -->
    <delete id="deleteById">
        DELETE FROM category WHERE id = #{id}
    </delete>
    
    <!-- 更新分类 -->
    <update id="update" parameterType="com.bjutzxq.pojo.Category">
        UPDATE category
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="parentId != null">
                parent_id = #{parentId},
            </if>
            <if test="sortOrder != null">
                sort_order = #{sortOrder},
            </if>
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 根据 ID 查询分类 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM category WHERE id = #{id}
    </select>
    
    <!-- 查询所有分类（支持按父分类筛选） -->
    <select id="selectByParentId" resultMap="BaseResultMap">
        SELECT * FROM category
        <where>
            <if test="parentId != null">
                parent_id = #{parentId}
            </if>
            <if test="parentId == null">
                parent_id IS NULL OR parent_id = 0
            </if>
        </where>
        ORDER BY sort_order ASC, id ASC
    </select>
    
    <!-- 查询所有分类 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM category ORDER BY sort_order ASC, id ASC
    </select>
    
    <!-- 根据名称查询分类 -->
    <select id="selectByName" resultMap="BaseResultMap">
        SELECT * FROM category WHERE name LIKE CONCAT('%', #{name}, '%') ORDER BY sort_order ASC, id ASC
    </select>
    
    <!-- 检查分类名称是否存在（排除自身） -->
    <select id="countByNameExcludeId" resultType="int">
        SELECT COUNT(*) FROM category 
        WHERE name = #{name} AND id != #{excludeId}
    </select>
</mapper>
