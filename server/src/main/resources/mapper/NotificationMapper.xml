<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//myBatis//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bjutzxq.server.mapper.NotificationMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.bjutzxq.pojo.Notification">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="sender_id" property="senderId"/>
        <result column="project_id" property="projectId"/>
        <result column="type" property="type"/>
        <result column="content" property="content"/>
        <result column="is_read" property="isRead"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, user_id, sender_id, project_id, type, content, is_read, created_at
    </sql>
    
    <!-- 根据 ID 查询通知 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM notification
        WHERE id = #{id}
    </select>
    
    <!-- 查询用户的通知列表（分页） -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM notification
        WHERE user_id = #{userId}
        <if test="isRead != null">
            AND is_read = #{isRead}
        </if>
        ORDER BY created_at DESC
    </select>
    
    <!-- 查询用户的未读通知数量 -->
    <select id="countUnreadByUserId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM notification
        WHERE user_id = #{userId}
        AND is_read = 0
    </select>
    
    <!-- 插入通知 -->
    <insert id="insert" parameterType="com.bjutzxq.pojo.Notification" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notification (
            user_id,
            sender_id,
            project_id,
            type,
            content,
            is_read
        ) VALUES (
            #{userId},
            #{senderId},
            #{projectId},
            #{type},
            #{content},
            #{isRead}
        )
    </insert>
    
    <!-- 批量插入通知 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO notification (
            user_id,
            sender_id,
            project_id,
            type,
            content,
            is_read
        ) VALUES
        <foreach collection="notifications" item="notification" separator=",">
            (
                #{notification.userId},
                #{notification.senderId},
                #{notification.projectId},
                #{notification.type},
                #{notification.content},
                #{notification.isRead}
            )
        </foreach>
    </insert>
    
    <!-- 更新通知 -->
    <update id="update" parameterType="com.bjutzxq.pojo.Notification">
        UPDATE notification
        <set>
            <if test="isRead != null">is_read = #{isRead},</if>
            <if test="content != null">content = #{content},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 将用户的所有未读通知标记为已读 -->
    <update id="markAllAsRead">
        UPDATE notification
        SET is_read = 1
        WHERE user_id = #{userId}
        AND is_read = 0
    </update>
    
    <!-- 将指定通知标记为已读 -->
    <update id="markAsRead">
        UPDATE notification
        SET is_read = 1
        WHERE id = #{notificationId}
    </update>
    
    <!-- 删除通知 -->
    <delete id="deleteById">
        DELETE FROM notification
        WHERE id = #{id}
    </delete>
    
    <!-- 批量删除通知 -->
    <delete id="batchDelete">
        DELETE FROM notification
        WHERE id IN
        <foreach collection="notificationIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    
</mapper>
