<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//myBatis//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bjutzxq.server.mapper.UserMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.bjutzxq.pojo.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="student_id" property="studentId"/>
        <result column="real_name" property="realName"/>
        <result column="class_name" property="className"/>
        <result column="email" property="email"/>
        <result column="avatar" property="avatar"/>
        <result column="phone" property="phone"/>
        <result column="sex" property="sex"/>
        <result column="bio" property="bio"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="status" property="status"/>
        <!-- 使用默认的 EnumTypeHandler，存储枚举名称：USER, TEACHER, ADMIN -->
        <result column="role" property="role"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, username, password, student_id, real_name, class_name, email, avatar, phone, sex, bio, created_at, updated_at, status, role
    </sql>
    
    <!-- 根据用户名查询 -->
    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM user
        WHERE username = #{username}
    </select>
    
    <!-- 根据邮箱查询 -->
    <select id="selectByEmail" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM user
        WHERE email = #{email}
    </select>
    
    <!-- 根据学号查询 -->
    <select id="selectByStudentId" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM user
        WHERE student_id = #{studentId}
    </select>
    
    <!-- 根据 ID 查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM user
        WHERE id = #{id}
    </select>
    
    <!-- 插入用户 -->
    <insert id="insert" parameterType="com.bjutzxq.pojo.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (
            username,
            password,
            student_id,
            real_name,
            class_name,
            email,
            avatar,
            phone,
            sex,
            bio,
            status,
            role
        ) VALUES (
            #{username},
            #{password},
            #{studentId},
            #{realName},
            #{className},
            #{email},
            #{avatar},
            #{phone},
            #{sex},
            #{bio},
            #{status},
            #{role}
        )
    </insert>
    
    <!-- 更新用户 -->
    <update id="update" parameterType="com.bjutzxq.pojo.User">
        UPDATE user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="realName != null">real_name = #{realName},</if>
            <if test="className != null">class_name = #{className},</if>
            <if test="email != null">email = #{email},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="sex != null">sex = #{sex},</if>
            <if test="bio != null">bio = #{bio},</if>
            <if test="status != null">status = #{status},</if>
            <if test="role != null">role = #{role},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 删除用户 -->
    <delete id="deleteById">
        DELETE FROM user
        WHERE id = #{id}
    </delete>
    
    <!-- 查询所有用户 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM user
        ORDER BY created_at DESC
    </select>
    
    <!-- 统计用户总数 -->
    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM user
    </select>
    
    <!-- 根据关键词搜索用户 -->
    <select id="searchByKeyword" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM user
        WHERE username LIKE CONCAT('%', #{keyword}, '%')
           OR email LIKE CONCAT('%', #{keyword}, '%')
           OR student_id LIKE CONCAT('%', #{keyword}, '%')
        ORDER BY created_at DESC
    </select>
    
</mapper>
