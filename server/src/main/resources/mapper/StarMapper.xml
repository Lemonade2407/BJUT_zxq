<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//myBatis//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bjutzxq.server.mapper.StarMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.bjutzxq.pojo.Star">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="project_id" property="projectId"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, user_id, project_id, created_at
    </sql>

    <!-- 新增点赞 -->
    <insert id="insert" parameterType="com.bjutzxq.pojo.Star" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO star (
            user_id,
            project_id,
            created_at
        ) VALUES (
            #{userId},
            #{projectId},
            NOW()
        )
    </insert>
    
    <!-- 根据用户 ID 和项目 ID 查询点赞记录 -->
    <select id="selectByUserIdAndProjectId" resultMap="BaseResultMap">
        SELECT 
            <include refid="Base_Column_List"/>
        FROM star
        WHERE user_id = #{userId} AND project_id = #{projectId}
        LIMIT 1
    </select>
    
    <!-- 删除点赞记录 -->
    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM star WHERE id = #{id}
    </delete>
    
    <!-- 统计项目点赞数 -->
    <select id="countByProjectId" resultType="int">
        SELECT COUNT(*) 
        FROM star
        WHERE project_id = #{projectId}
    </select>
    
</mapper>
